# Copy to .env for local development: `cp .env.example .env`
# Compose files and services read these values.

# --- PostgreSQL (operational state) ---
PG_HOST=localhost
PG_PORT=5432
PG_USER=epi_os
PG_PASSWORD=epi_os
PG_DATABASE=epi_os

# --- MongoDB (project evidence store) ---
MONGO_URI=mongodb://localhost:27017/epi_os

# --- ChromaDB (vector store) — serves on 8000, so APIs use 8001-8004 ---
CHROMA_HOST=localhost
CHROMA_PORT=8000

# --- Airflow (operational scheduler) ---
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# --- Dataset acquisition (Initial Dataset download) ---
DEFAULT_DATASET_ID=public-jira
ACQUIRE_DAG_ID=project_dataset_acquire
# Where the Airflow acquire DAG writes the downloaded archive (in-container path).
DATASET_DATA_DIR=/opt/airflow/data
# Admin-API -> Ingestion-API governed boundary (dataset ops are owned there).
INGESTION_API_BASE_URL=http://localhost:8001

# --- Middleware service ports ---
INGESTION_API_PORT=8001
ADMIN_API_PORT=8002
PROJECTS_API_PORT=8003
RISK_ANALYTICS_API_PORT=8004

# --- Logging ---
LOG_LEVEL=INFO

# --- Agent model + framework (used from the risk-analytics phase onward) ---
# Default reasoning model for agents (Claude).
AGENT_MODEL=claude-opus-4-8
# Default agent orchestration framework. Toggle per-agent via Admin-API config.
# One of: langgraph | crewai | openai_agents | strands | google_adk | ms_agent_framework
AGENT_FRAMEWORK=langgraph
# ANTHROPIC_API_KEY=set-in-.env-not-here

# --- Observability: LangSmith tracing (LangChain/LangGraph auto-trace) ---
# Traces every agent LLM call + the detector fan-out + review pipeline.
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=enterprise-project-intelligence-os
# LANGSMITH_API_KEY=set-in-.env-not-here
